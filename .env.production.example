# ==================== PRODUCTION ENVIRONMENT TEMPLATE ====================
# Copy this file to .env and fill in actual production values
# NEVER commit actual .env file to version control

# ==================== CORE CONFIGURATION ====================
NODE_ENV=production
PORT=3000
LOG_LEVEL=info

# ==================== DATABASE ====================
# MongoDB Atlas connection string (recommended for production)
# Format: mongodb+srv://username:password@cluster.mongodb.net/dbname
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/?appName=MamaCheck

# ==================== AUTHENTICATION ====================
# Use strong, random secrets (minimum 32 characters)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_very_long_random_secret_here_minimum_32_chars
JWT_REFRESH_SECRET=another_very_long_random_secret_here_minimum_32_chars
JWT_EXPIRY=7d
JWT_REFRESH_EXPIRY=30d

# ==================== SMS GATEWAY (TWILIO) ====================
# Get from: https://www.twilio.com/console
TWILIO_ACCOUNT_SID=AC...your_account_sid...
TWILIO_AUTH_TOKEN=your_auth_token...
TWILIO_PHONE_NUMBER=+1234567890

# ==================== AI SERVICE ====================
# Get from: https://console.groq.com/keys
GROQ_API_KEY=gsk_...your_groq_api_key...

# ==================== SEEDING ====================
# Used only during initial database setup (seed:prod)
# Must be at least 8 characters
SEED_ADMIN_PASSWORD=SecureAdminPassword123!
SEED_CHEW_PASSWORD=SecureCHEWPassword123!

# ==================== OPTIONAL SERVICES ====================
# Redis for distributed caching (improves performance)
REDIS_URL=redis://user:password@redis-host.com:6379

# Slack for critical alerts (optional but recommended)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ==================== CORS & FRONTEND ====================
# Comma-separated list of allowed origins
CORS_ORIGIN=https://yourdomain.com,https://app.yourdomain.com
FRONTEND_URL=https://yourdomain.com

# ==================== RATES & LIMITS ====================
# 100 requests per 15 minutes (900000ms)
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=900000

# ==================== PRODUCTION CHECKLIST ====================
# Before deploying to production:
#
# 1. ✅ Update MONGODB_URI to production database
# 2. ✅ Generate new JWT_SECRET and JWT_REFRESH_SECRET
# 3. ✅ Configure real Twilio credentials
# 4. ✅ Add Groq API key
# 5. ✅ Set strong SEED_*_PASSWORD values
# 6. ✅ Configure Redis (or accept performance trade-off)
# 7. ✅ Add Slack webhook for monitoring
# 8. ✅ Set correct CORS_ORIGIN for your domain
# 9. ✅ Verify LOG_LEVEL=info (not debug)
# 10. ✅ NEVER commit .env file - use secret management service
#
# Recommended: Use AWS Secrets Manager, HashiCorp Vault, or similar
