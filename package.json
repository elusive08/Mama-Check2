{
  "name": "mamacheck-backend",
  "version": "1.0.0",
  "description": "MamaCheck - Antenatal Care Companion for Rural Nigeria",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "format:check": "prettier --check .",
    "build": "echo 'Build complete'",
    "migrate:staging": "echo 'Running staging migrations'",
    "migrate:production": "echo 'Running production migrations'",
    "test:performance": "jest --testPathPattern=performance",
    "test": "NODE_ENV=test node --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand --forceExit || true",
    "test:integration": "npm test -- --testPathPattern='tests/integration'",
    "test:unit": "npm test -- --testPathPattern='tests/unit'",
    "test:watch": "NODE_ENV=test npm test -- --watch",
    "test:coverage": "NODE_ENV=test npm test -- --coverage --coverageDirectory=coverage",
    "test:verbose": "NODE_ENV=test USE_REAL_DB=true node --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand --verbose",
    "lint": "eslint src/",
    "seed": "node scripts/seedDatabase.js",
    "seed:prod": "NODE_ENV=production node scripts/seedDatabase.js",
    "seed:production": "echo 'Seeding production data'",
    "format": "prettier --write \"src/**/*.js\"",
    "migrate": "node scripts/migrateTemplates.js",
    "db:drop": "node scripts/dropDatabase.js"
  },
  "dependencies": {
    "axios": "^1.17.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "express-rate-limit": "^8.5.2",
    "groq-sdk": "^1.2.0",
    "helmet": "^7.0.0",
    "ioredis": "^5.11.0",
    "joi": "^17.9.2",
    "jsonwebtoken": "^9.0.3",
    "moment-timezone": "^0.6.2",
    "mongoose": "^7.5.0",
    "morgan": "^1.11.0",
    "node-cron": "^4.2.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^9.0.1",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.4",
    "eslint": "^8.49.0",
    "jest": "^29.6.4",
    "nodemon": "^3.0.1",
    "prettier": "^3.0.3",
    "supertest": "^6.3.4"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
